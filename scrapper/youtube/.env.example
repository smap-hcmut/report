# YouTube Scraper Configuration
# Copy this file to .env and configure your settings

# ========== RabbitMQ Settings ==========
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=youtube_crawl_queue
RABBITMQ_EXCHANGE=youtube_exchange
RABBITMQ_ROUTING_KEY=youtube.crawl
RABBITMQ_PREFETCH_COUNT=1

# ========== Result Publisher Settings ==========
# Configuration for publishing crawl results to Collector Service
RESULT_PUBLISHER_ENABLED=true
RESULT_EXCHANGE_NAME=youtube_exchange
RESULT_ROUTING_KEY=youtube.res
RESULT_QUEUE_NAME=youtube_result_queue

# ========== Event Publisher Settings (Event-Driven Architecture) ==========
# Configuration for data.collected events - MUST use smap.events exchange  
EVENT_PUBLISHER_ENABLED=true # Enable data.collected event publishing
EVENT_EXCHANGE_NAME=smap.events # Main events exchange (event-driven architecture)
EVENT_ROUTING_KEY=data.collected # Routing key for data.collected events

# ========== Batch Upload Settings ==========
# Batch upload to MinIO for Analytics Service consumption
BATCH_SIZE=20 # Number of items per batch (BATCH_SIZE_YOUTUBE in docs)
BATCH_UPLOAD_ENABLED=true
MINIO_CRAWL_RESULTS_BUCKET=crawl-results

# ========== MongoDB Settings ==========
MONGODB_HOST=localhost
MONGODB_PORT=27017
# MONGODB_USER=admin
# MONGODB_PASSWORD=password
MONGODB_DATABASE=youtube_crawl
MONGODB_AUTH_SOURCE=admin

# ========== Crawler Settings ==========
CRAWLER_QUIET=true
CRAWLER_NO_WARNINGS=true
CRAWLER_MAX_CONCURRENT=8
CRAWLER_MAX_COMMENTS=200

# ========== Limit Settings ==========
# Default limits (applied when payload doesn't specify)
DEFAULT_SEARCH_LIMIT=50           # Default for research_keyword, dryrun_keyword
DEFAULT_LIMIT_PER_KEYWORD=50      # Default for research_and_crawl
DEFAULT_CHANNEL_LIMIT=100         # Default for fetch_channel_content
DEFAULT_CRAWL_LINKS_LIMIT=200     # Default max URLs for crawl_links

# Hard limits (safety caps to prevent resource exhaustion)
MAX_SEARCH_LIMIT=500              # Maximum for search-based tasks
MAX_CRAWL_LINKS_LIMIT=1000        # Maximum for crawl_links
MAX_CHANNEL_LIMIT=500             # Maximum for fetch_channel_content

# ========== Media Download Settings ==========
MEDIA_DOWNLOAD_DIR=./downloads
MEDIA_DOWNLOAD_ENABLED=true
MEDIA_DEFAULT_TYPE=audio

# Remote FFmpeg Service Configuration
MEDIA_FFMPEG_SERVICE_URL=http://ffmpeg-service:8000  # Remote FFmpeg service endpoint
MEDIA_FFMPEG_TIMEOUT=600  # Conversion timeout in seconds
MEDIA_FFMPEG_MAX_RETRIES=3  # Max retry attempts for transient failures
MEDIA_FFMPEG_BACKOFF_FACTOR=2.0  # Exponential backoff multiplier (1s, 2s, 4s...)
MEDIA_FFMPEG_CIRCUIT_BREAKER=true  # Enable circuit breaker pattern
MEDIA_FFMPEG_CIRCUIT_THRESHOLD=5  # Failures before opening circuit
MEDIA_FFMPEG_CIRCUIT_RECOVERY=60.0  # Seconds before attempting recovery
MEDIA_FFMPEG_MAX_CONNECTIONS=100  # Max HTTP connections in pool
MEDIA_FFMPEG_KEEPALIVE_CONNECTIONS=20  # Max idle connections to keep alive

MEDIA_MAX_FILE_SIZE_MB=500
MEDIA_DOWNLOAD_TIMEOUT=300
MEDIA_CHUNK_SIZE=8192
MEDIA_UPLOAD_TO_STORAGE=false


# ========== Compression Settings ==========
# Enable Zstd compression for data uploads
COMPRESSION_ENABLED=true

# Compression algorithm (currently only "zstd" supported)
COMPRESSION_ALGORITHM=zstd

# Default compression level: 0=none, 1=fast, 2=default (recommended), 3=best
# Level 2 provides 70-85% reduction with balanced speed
COMPRESSION_DEFAULT_LEVEL=2

# Don't compress files smaller than this (in bytes)
COMPRESSION_MIN_SIZE_BYTES=1024

# ========== Async Upload Settings ==========
# Enable async (non-blocking) uploads
# When enabled, uploads return immediately and process in background
MINIO_ASYNC_UPLOAD_ENABLED=true

# Number of concurrent upload workers (1-16)
# Higher values = more concurrent uploads, more memory usage
MINIO_ASYNC_UPLOAD_WORKERS=4

# Maximum number of tasks in upload queue
MINIO_ASYNC_UPLOAD_QUEUE_SIZE=100

# Upload chunk size in bytes (5MB default)
MINIO_UPLOAD_CHUNK_SIZE=5242880

# Progress update interval in seconds
MINIO_PROGRESS_UPDATE_INTERVAL=0.5

# ========== Archival Settings ==========
ENABLE_JSON_ARCHIVE=true
ENABLE_DB_PERSISTENCE=true
MINIO_ARCHIVE_BUCKET=youtube-archive

# ========== Metadata Settings ==========
DEFAULT_LANG=vi
DEFAULT_REGION=VN
PIPELINE_VERSION=crawler_youtube_v3

# ========== Gemini AI Summary Settings ==========
# Enable AI-powered video summarization (recommended - faster and cheaper than FFmpeg)
GEMINI_ENABLED=true
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=120
GEMINI_TRANSCRIPT_LANGUAGES=en,vi,en-US,en-GB,vi-VN

# ========== MinIO Storage Settings ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smap-stt-audio-files
MINIO_USE_SSL=false
MINIO_BASE_PATH=

# ========== Application Settings ==========
APP_ENV=development
LOG_LEVEL=INFO
WORKER_NAME=youtube-worker-1
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=5
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT=30

# ========== Speech-to-Text Settings ==========
# Enable automatic audio transcription after FFmpeg conversion
STT_API_ENABLED=true

# STT API endpoint
STT_API_URL=http://172.16.21.230/transcribe

# STT API authentication key
STT_API_KEY=smap-internal-key-changeme

# STT request timeout in seconds (per HTTP request, not total transcription time)
STT_TIMEOUT=300

# Presigned URL expiration time in hours (7 days)
STT_PRESIGNED_URL_EXPIRES_HOURS=168

# ========== STT Async Polling Configuration ==========
# Maximum number of polling attempts to check transcription job status
# Total max wait time = STT_POLLING_MAX_RETRIES × STT_POLLING_WAIT_INTERVAL
# Default: 60 retries × 3 seconds = 3 minutes maximum wait
STT_POLLING_MAX_RETRIES=60

# Wait interval in seconds between polling attempts
# Recommended: 2-5 seconds to balance responsiveness and API load
STT_POLLING_WAIT_INTERVAL=3
