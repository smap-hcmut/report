@startuml
skinparam style strictuml
skinparam shadowing false
skinparam defaultFontName Arial

|Người dùng chuyên môn nội bộ|
start
:Yêu cầu thiết lập chiến dịch theo dõi;

|Hệ thống SMAP|
:Tiếp nhận và lưu cấu hình campaign,
project, nguồn dữ liệu và mục tiêu thu thập;

|Người dùng chuyên môn nội bộ|
if (Có cần quản lý quy tắc
cảnh báo khủng hoảng?) then ([Có])
  :Thiết lập hoặc cập nhật
  quy tắc cảnh báo khủng hoảng;
else ([Không])
endif

:Yêu cầu vận hành chiến dịch theo dõi;

|Hệ thống SMAP|
:Đánh giá mức độ sẵn sàng và
chuyển trạng thái vận hành phù hợp;

|Người dùng chuyên môn nội bộ|
if (Tiếp tục theo dõi trạng thái
và cảnh báo?) then ([Có])
  :Theo dõi trạng thái và
  nhận cảnh báo;
else ([Không])
endif

if (Khai thác dữ liệu phân tích?) then ([Có])
  :Tra cứu và hỏi đáp
  dữ liệu phân tích;
else ([Không])
endif
stop
@enduml
