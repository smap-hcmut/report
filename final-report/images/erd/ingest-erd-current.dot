digraph IngestERD {
  graph [rankdir=TB, splines=polyline, nodesep=0.6, ranksep=0.8, pad=0.2, margin=0, bgcolor="white"];
  node [shape=plain, margin=0, fontname="Arial"];
  edge [color="#7f7f7f", penwidth=1.3, fontname="Arial", fontsize=11];

  datasource [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">DATA_SOURCES</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">project_id</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">External project ref</TD></TR>
      <TR><TD ALIGN="LEFT">varchar/enum</TD><TD ALIGN="LEFT">name, source_type, source_category</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status, onboarding_status, dryrun_status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">config, account_ref, mapping_rules</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum/int</TD><TD ALIGN="LEFT">crawl_mode, crawl_interval_minutes</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">dryrun_last_result_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Optional</TD></TR>
    </TABLE>
  >];

  targets [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">CRAWL_TARGETS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">data_source_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Ref DATA_SOURCES.id</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">target_type</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">KEYWORD | PROFILE | POST_URL</TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">values, platform_meta</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">bool/int</TD><TD ALIGN="LEFT">is_active, priority, crawl_interval_minutes</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  dryrun [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">DRYRUN_RESULTS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">source_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">target_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Nullable</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">PENDING..FAILED</TD></TR>
      <TR><TD ALIGN="LEFT">jsonb/text</TD><TD ALIGN="LEFT">sample_data, warnings, error_message</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  jobs [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">SCHEDULED_JOBS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">source_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">target_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Nullable</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status, trigger_type, crawl_mode</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">payload</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  ext [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">EXTERNAL_TASKS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">source_id, scheduled_job_id, target_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">task_id</TD><TD ALIGN="CENTER">UK</TD><TD ALIGN="LEFT">Correlation key</TD></TR>
      <TR><TD ALIGN="LEFT">varchar/enum</TD><TD ALIGN="LEFT">platform, task_type, status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">request_payload</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  raw [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">RAW_BATCHES</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">source_id, external_task_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">batch_id, storage_bucket</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">storage_path, storage_url</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status, publish_status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">raw_metadata</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  modechg [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">CRAWL_MODE_CHANGES</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">source_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">trigger_type, from_mode, to_mode</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">int</TD><TD ALIGN="LEFT">from_interval_minutes, to_interval_minutes</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  { rank=same; dryrun; jobs; }
  { rank=same; ext; raw; }
  datasource -> targets [arrowhead=none, label="owns many"];
  datasource -> dryrun [arrowhead=none, label="evidence"];
  datasource -> jobs [arrowhead=none, label="schedules"];
  jobs -> ext [arrowhead=none, label="dispatches"];
  ext -> raw [arrowhead=none, label="materializes"];
  datasource -> modechg [arrowhead=none, label="tracks mode changes"];
}
