digraph ProjectERD {
  graph [rankdir=TB, splines=polyline, nodesep=0.8, ranksep=0.9, pad=0.2, margin=0, bgcolor="white"];
  node [shape=plain, margin=0, fontname="Arial"];
  edge [color="#7f7f7f", penwidth=1.4, fontname="Arial", fontsize=12];

  campaigns [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">CAMPAIGNS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">name</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">description</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">campaign_status</TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">start_date, end_date</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">created_by</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">External identity ref</TD></TR>
      <TR><TD ALIGN="LEFT">uuid[]</TD><TD ALIGN="LEFT">favorite_user_ids</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">GIN indexed</TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at, updated_at, deleted_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  projects [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">PROJECTS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">campaign_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Ref CAMPAIGNS.id</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">name</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">text / varchar</TD><TD ALIGN="LEFT">description, brand</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">entity_type</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">product | campaign | ...</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">entity_name</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">domain_type_code</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">Default `_default`</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">project_status</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">config_status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">project_config_status</TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">created_by</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">External identity ref</TD></TR>
      <TR><TD ALIGN="LEFT">uuid[]</TD><TD ALIGN="LEFT">favorite_user_ids</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">GIN indexed</TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at, updated_at, deleted_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  crisis [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">PROJECTS_CRISIS_CONFIG</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">project_id</TD><TD ALIGN="CENTER">PK/FK</TD><TD ALIGN="LEFT">Ref PROJECTS.id</TD></TR>
      <TR><TD ALIGN="LEFT">enum</TD><TD ALIGN="LEFT">status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">NORMAL | WARNING | CRITICAL</TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">keywords_rules</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">volume_rules</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">sentiment_rules</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">influencer_rules</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at, updated_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  { rank=same; campaigns; projects; crisis; }
  campaigns -> projects [arrowhead=none, label="contains"];
  projects -> crisis [arrowhead=none, label="has optional config"];
}
