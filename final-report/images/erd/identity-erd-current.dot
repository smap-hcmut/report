digraph IdentityERD {
  graph [
    rankdir=TB,
    splines=polyline,
    nodesep=0.9,
    ranksep=0.9,
    pad=0.2,
    margin=0,
    bgcolor="white"
  ];

  node [shape=plain, margin=0, fontname="Arial"];
  edge [color="#7f7f7f", penwidth=1.4, fontname="Arial", fontsize=12];

  users [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">USERS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">email</TD><TD ALIGN="CENTER">UK</TD><TD ALIGN="LEFT">OAuth principal</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">name</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">avatar_url</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">role_hash</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">Protected role</TD></TR>
      <TR><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">is_active</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">last_login_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  jwtkeys [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">JWT_KEYS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">kid</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT">Key identifier</TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">private_key</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">Encrypted at rest</TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">public_key</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">JWKS material</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">status</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">active | rotating | retired</TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">expires_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">retired_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  auditlogs [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#8f7cff">
      <TR><TD BGCOLOR="#f5f2ff" COLSPAN="4"><FONT POINT-SIZE="16">AUDIT_LOGS</FONT></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">id</TD><TD ALIGN="CENTER">PK</TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">uuid</TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="CENTER">FK</TD><TD ALIGN="LEFT">Ref USERS.id</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">action</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT">Required</TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">resource_type</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">varchar</TD><TD ALIGN="LEFT">resource_id</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">inet</TD><TD ALIGN="LEFT">ip_address</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">user_agent</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">jsonb</TD><TD ALIGN="LEFT">metadata</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
      <TR><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT">created_at</TD><TD ALIGN="CENTER"></TD><TD ALIGN="LEFT"></TD></TR>
    </TABLE>
  >];

  { rank=same; users; jwtkeys; }
  users -> jwtkeys [style=invis];
  users -> auditlogs [arrowhead=none, label="has many"];
  jwtkeys -> auditlogs [style=invis];
}
