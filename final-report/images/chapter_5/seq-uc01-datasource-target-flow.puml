@startuml
skinparam defaultFontName Arial
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 70
skinparam roundcorner 12

actor User
participant "Giao diện" as UI
participant "Ingest Service" as IngestService
participant "Project Service" as ProjectService

User -> UI : Mở cấu hình nguồn dữ liệu
UI -> IngestService : POST /datasources
activate IngestService
opt Kiểm tra project context khi tạo datasource
  IngestService -> ProjectService : GET project detail
  activate ProjectService
  ProjectService --> IngestService : project available
  deactivate ProjectService
end
IngestService --> UI : datasource metadata
deactivate IngestService

loop Mỗi target cần khai báo
  User -> UI : Thêm keyword, profile hoặc post URL
  UI -> IngestService : POST /datasources/{id}/targets/*
  activate IngestService
  IngestService --> UI : target metadata
  deactivate IngestService
end

UI --> User : Hiển thị datasource, target\nand readiness state ban đầu
@enduml
