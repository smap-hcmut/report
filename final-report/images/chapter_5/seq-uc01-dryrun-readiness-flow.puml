@startuml
skinparam defaultFontName Arial
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 70
skinparam roundcorner 12

actor User
participant "Giao diện" as UI
participant "Ingest Service" as IngestService
queue "RabbitMQ task queue" as TaskQueue
participant "Scrapper Worker" as Worker
database "Artifact Storage" as Storage
queue "RabbitMQ completion queue" as CompletionQueue

User -> UI : Yêu cầu kiểm tra thử
UI -> IngestService : POST /datasources/{id}/dryrun
activate IngestService
IngestService ->> TaskQueue : publish dryrun task
IngestService --> UI : dryrun accepted\n(status=RUNNING)
deactivate IngestService

TaskQueue ->> Worker : deliver dryrun task
activate Worker
Worker -> Worker : Lấy mẫu hoặc xác nhận khả năng truy cập
opt Có sample artifact
  Worker -> Storage : save sample artifact
  activate Storage
  Storage --> Worker : artifact metadata
  deactivate Storage
end
Worker ->> CompletionQueue : publish dryrun completion
deactivate Worker

CompletionQueue ->> IngestService : deliver dryrun completion
activate IngestService
IngestService -> IngestService : update latest result and readiness
deactivate IngestService

loop User kiểm tra readiness
  UI -> IngestService : GET /datasources/{id}/dryrun/latest
  activate IngestService
  IngestService --> UI : latest dryrun result\nand readiness state
  deactivate IngestService
end

UI --> User : Hiển thị kết quả kiểm tra thử
@enduml
