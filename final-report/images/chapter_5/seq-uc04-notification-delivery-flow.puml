@startuml
skinparam defaultFontName Arial
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 70
skinparam roundcorner 12

participant "Backend Publisher" as Publisher
participant "Redis Pub/Sub" as Redis
participant "Notification Service" as NotificationService
participant "Giao diện" as UI
actor User

Publisher ->> Redis : publish notification event
Redis ->> NotificationService : matched channel message
activate NotificationService

opt Có kênh nhận thông báo tương thích
  NotificationService --> UI : push notification or alert payload
  UI --> User : Hiển thị thông báo hoặc cảnh báo
end

deactivate NotificationService
@enduml
