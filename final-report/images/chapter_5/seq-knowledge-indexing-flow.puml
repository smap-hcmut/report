@startuml
title Knowledge Indexing Phase 1 - Intake and Routing
skinparam defaultFontName Arial
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 70
skinparam roundcorner 12

queue "Kafka topics\nanalytics.*" as AnalyticsTopics
participant "Kafka Consumer" as Consumer
participant "IndexingUseCase" as Indexing

AnalyticsTopics ->> Consumer : deliver analytics event
activate Consumer
Consumer -> Consumer : unmarshal by topic and payload shape

alt batch.completed with documents[]
  Consumer -> Indexing : IndexBatch(input)
  activate Indexing
  Indexing --> Consumer : batch indexing result
  deactivate Indexing
else insights.published with should_index=true
  Consumer -> Indexing : IndexInsight(input)
  activate Indexing
  Indexing --> Consumer : insight indexing result
  deactivate Indexing
else report.digest with should_index=true
  Consumer -> Indexing : IndexDigest(input)
  activate Indexing
  Indexing --> Consumer : digest indexing result
  deactivate Indexing
else unsupported or skipped payload
  Consumer -> Consumer : ignore message
end

deactivate Consumer
@enduml
