@startuml
skinparam defaultFontName Arial
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 70
skinparam roundcorner 12

actor User
participant "Giao diện" as UI
participant "Project Service" as ProjectService

User -> UI : Chọn tạo chiến dịch theo dõi

alt Tạo campaign mới
  UI -> ProjectService : POST /campaigns
  activate ProjectService
  ProjectService --> UI : campaign context
  deactivate ProjectService
else Dùng campaign đã tồn tại
  User -> UI : Chọn campaign hiện có
  UI -> UI : Nạp campaign context
end

User -> UI : Nhập thông tin đối tượng theo dõi
UI -> ProjectService : POST /campaigns/{id}/projects
activate ProjectService
ProjectService --> UI : project context\n(project_id, status=PENDING)
deactivate ProjectService
UI --> User : Hiển thị campaign và project đã tạo
@enduml
