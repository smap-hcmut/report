# ========================================
# ========== RabbitMQ Configuration ==========
# Note: Port 5672 is for AMQP connection, Port 15672 is for Web Management UI
# ========================================
RABBITMQ_HOST=<your_rabbitmq_host>
RABBITMQ_PORT=5672
RABBITMQ_USER=<your_rabbitmq_user>
RABBITMQ_PASSWORD=<your_rabbitmq_password>
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=<your_queue_name>
RABBITMQ_EXCHANGE=<your_exchange_name>
RABBITMQ_ROUTING_KEY=<your_routing_key>
RABBITMQ_PREFETCH_COUNT=1

# ========================================
# ========== MongoDB Configuration ==========
# ========================================
MONGODB_HOST=<your_mongodb_host>
MONGODB_PORT=27017
MONGODB_USER=<your_mongodb_user>
MONGODB_PASSWORD=<your_mongodb_password>
MONGODB_DATABASE=<your_database_name>
MONGODB_AUTH_SOURCE=<your_auth_source>

# ========================================
# ========== Crawler Settings ==========
# ========================================
CRAWLER_HEADLESS=True
CRAWLER_TIMEOUT=30000
CRAWLER_WAIT_AFTER_LOAD=3000
CRAWLER_SCROLL_DELAY=1500
CRAWLER_MAX_SCROLL_ATTEMPTS=10
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Remote Playwright Service (leave empty to use local browser)
# When set, connects to a remote Playwright service instead of launching a local browser
# Example: ws://playwright-service:4444/?headless=1
PLAYWRIGHT_WS_ENDPOINT=ws://playwright-service:4444/?headless=1
PLAYWRIGHT_REST_API_ENABLED=True
PLAYWRIGHT_REST_API_URL=http://playwright-service:8001 # Example: http://localhost:8001 or http://playwright-service:8001

# ========== Speech-to-Text Settings ==========
STT_API_ENABLED=true # Enable STT transcription for video audio
STT_API_URL=http://172.16.21.230/transcribe # STT API endpoint URL
STT_API_KEY=smap-internal-key-changeme # API key for STT service authentication
STT_TIMEOUT=300 # Request timeout in seconds for STT API calls
STT_PRESIGNED_URL_EXPIRES_HOURS=168 # Presigned URL expiration time in hours (default: 7 days)

# Async STT polling configuration
STT_POLLING_MAX_RETRIES=60 # Maximum number of polling attempts (default: 60)
STT_POLLING_WAIT_INTERVAL=3 # Seconds to wait between polling attempts (default: 3)

# Concurrent crawling
CRAWLER_MAX_CONCURRENT=8
# Rate limiting
CRAWLER_REQUESTS_PER_MINUTE=20
CRAWLER_DELAY_MIN=2
CRAWLER_DELAY_MAX=5

# ========== Limit Settings ==========
# Default limits (applied when payload doesn't specify)
DEFAULT_SEARCH_LIMIT=50           # Default for research_keyword, dryrun_keyword
DEFAULT_LIMIT_PER_KEYWORD=50      # Default for research_and_crawl
DEFAULT_PROFILE_LIMIT=100         # Default for fetch_profile_content
DEFAULT_CRAWL_LINKS_LIMIT=200     # Default max URLs for crawl_links

# Hard limits (safety caps to prevent resource exhaustion)
MAX_SEARCH_LIMIT=500              # Maximum for search-based tasks
MAX_CRAWL_LINKS_LIMIT=1000        # Maximum for crawl_links
MAX_PROFILE_LIMIT=500             # Maximum for fetch_profile_content

# ========== Media Download Settings (NEW) ==========
MEDIA_DOWNLOAD_DIR=./tiktok # Storage prefix for MinIO uploads
MEDIA_DOWNLOAD_ENABLED=True # Enable media downloads by default
MEDIA_DEFAULT_TYPE=audio # Default media type to download: "audio" or "video"
MEDIA_ENABLE_FFMPEG=True # Enable ffmpeg for audio extraction fallback
MEDIA_FFMPEG_PATH=ffmpeg # Path to ffmpeg executable
MEDIA_MAX_FILE_SIZE_MB=500 # Maximum file size in MB (prevents downloading huge files)
MEDIA_DOWNLOAD_TIMEOUT=300 # Download timeout in seconds
MEDIA_CHUNK_SIZE=8192 # Download chunk size in bytes (8KB default for streaming)

# ========== Application Settings ==========
# ========================================
APP_ENV=development
LOG_LEVEL=INFO

# Worker settings
WORKER_NAME=<your_worker_name>
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=5

# ========== Compression Settings (NEW) ==========
COMPRESSION_ENABLED=true # Enable Zstd compression for data uploads
COMPRESSION_ALGORITHM=zstd # Compression algorithm (currently only "zstd" supported)
# Level 2 provides 70-85% reduction with balanced speed
# Default compression level: 0=none, 1=fast, 2=default (recommended), 3=best
COMPRESSION_DEFAULT_LEVEL=2 
COMPRESSION_MIN_SIZE_BYTES=1024 # Don't compress files smaller than this (in bytes)


# ========== MinIO Configuration ==========
# ========================================
MINIO_ENDPOINT=<your_minio_host>:9000
MINIO_ACCESS_KEY=<your_minio_access_key>
MINIO_SECRET_KEY=<your_minio_secret_key>
MINIO_BUCKET=<your_bucket_for_audio_files>
MINIO_BUCKET_MODEL=<your_bucket_for_models>
MINIO_USE_SSL=False
# ========== Async Upload Settings (NEW) ==========
# Enable async (non-blocking) uploads
# When enabled, uploads return immediately and process in background
MINIO_ASYNC_UPLOAD_ENABLED=false
# Number of concurrent upload workers (1-16)
# Higher values = more concurrent uploads, more memory usage
MINIO_ASYNC_UPLOAD_WORKERS=4
# Maximum number of tasks in upload queue
MINIO_ASYNC_UPLOAD_QUEUE_SIZE=100
# Upload chunk size in bytes (5MB default)
MINIO_UPLOAD_CHUNK_SIZE=5242880
# Progress update interval in seconds
MINIO_PROGRESS_UPDATE_INTERVAL=0.5


# ========== Archival Settings ==========
ENABLE_JSON_ARCHIVE=True
MINIO_ARCHIVE_BUCKET=tiktok-archive
ENABLE_DB_PERSISTENCE=False

# ========== Result Publisher Settings ==========
# Configuration for publishing dry-run task results to collector exchange
RESULT_PUBLISHER_ENABLED=True # Enable result message publishing
RESULT_EXCHANGE_NAME=tiktok_exchange # Exchange for dry-run results
RESULT_ROUTING_KEY=tiktok.res # Routing key for result messages
RESULT_QUEUE_NAME=tiktok_result_queue # Queue for result messages

# ========== Event Publisher Settings (Event-Driven Architecture) ==========
# Configuration for data.collected events - MUST use smap.events exchange
EVENT_PUBLISHER_ENABLED=true # Enable data.collected event publishing
EVENT_EXCHANGE_NAME=smap.events # Main events exchange (event-driven architecture)
EVENT_ROUTING_KEY=data.collected # Routing key for data.collected events

# ========== Batch Upload Settings ==========
BATCH_SIZE=50 # Number of items per batch for MinIO upload (BATCH_SIZE_TIKTOK in docs)
BATCH_UPLOAD_ENABLED=true # Enable batch upload to MinIO
MINIO_CRAWL_RESULTS_BUCKET=crawl-results # MinIO bucket for batch crawl results

# ========== Metadata Settings ==========
DEFAULT_LANG=vi # Default language code for crawled content
DEFAULT_REGION=VN # Default region code for crawled content  
PIPELINE_VERSION=crawler_tiktok_v3 # Pipeline version identifier
