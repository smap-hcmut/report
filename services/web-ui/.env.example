# ============================================
# Environment Variables Example
# ============================================
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0

# API Configuration
# NEXT_PUBLIC_HOSTNAME is the base URL for the API
# Use NEXT_PUBLIC_ prefix for client-side access in Next.js
# Example: https://smap-api.tantai.dev/identity
NEXT_PUBLIC_HOSTNAME=http://localhost:3000

# WebSocket Configuration
# WebSocket URL for real-time project status updates
# Production: wss://smap-api.tantai.dev/ws
# Development: ws://localhost:8080/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Add your custom environment variables below:
# API_KEY=
# DATABASE_URL=
# SECRET_KEY=
