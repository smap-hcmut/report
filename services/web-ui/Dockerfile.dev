# ============================================
# Development Dockerfile for Next.js (Hot Reload)
# ============================================

FROM node:20-alpine

WORKDIR /app

# Improve compatibility with some native deps on Alpine
RUN apk add --no-cache libc6-compat

# Copy only package manifests first to leverage Docker layer cache
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci --legacy-peer-deps || npm install --legacy-peer-deps

# Copy the rest of the source code (will be overridden by volume in compose)
COPY . .

# Next.js dev server
EXPOSE 5000

# Useful envs for hot reload in Docker
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true
ENV HOSTNAME "0.0.0.0"
ENV PORT 5000
ENV NODE_ENV development
ENV NEXT_TELEMETRY_DISABLED 1

# Start dev server (install on container start in case lockfile changed)
CMD sh -c "npm install --legacy-peer-deps && npm run dev"


