# Environment Configuration
# Controls environment-specific behavior (CORS, logging, etc.)
# Values: "production" (strict security), "staging" (permissive), "dev" (permissive)
# Default: "production" (fail-safe)
# IMPORTANT: Set to "production" in production environments for security
ENV={{ENV}}

# HTTP Server Configuration
HOST={{HOST}}
APP_PORT={{APP_PORT}}
API_MODE={{API_MODE}}

# Logger Configuration
LOGGER_LEVEL={{LOGGER_LEVEL}}
LOGGER_MODE={{LOGGER_MODE}}
LOGGER_ENCODING={{LOGGER_ENCODING}}
LOGGER_COLOR_ENABLED={{LOGGER_COLOR_ENABLED}}

# PostgreSQL Configuration
POSTGRES_HOST={{POSTGRES_HOST}}
POSTGRES_PORT={{POSTGRES_PORT}}
POSTGRES_USER={{POSTGRES_USER}}
POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}
POSTGRES_DB={{POSTGRES_DB}}
POSTGRES_SSLMODE={{POSTGRES_SSLMODE}}

# Redis Configuration (Standalone mode only)
REDIS_HOST={{REDIS_HOST}}
REDIS_PASSWORD={{REDIS_PASSWORD}}
REDIS_DB={{REDIS_DB}}
REDIS_STATE_DB={{REDIS_STATE_DB}}
REDIS_MIN_IDLE_CONNS={{REDIS_MIN_IDLE_CONNS}}
REDIS_POOL_SIZE={{REDIS_POOL_SIZE}}
REDIS_POOL_TIMEOUT={{REDIS_POOL_TIMEOUT}}

# RabbitMQ Configuration
RABBITMQ_URL={{RABBITMQ_URL}}

# JWT Configuration
JWT_SECRET={{JWT_SECRET}}

# Cookie Configuration (for HttpOnly authentication)
COOKIE_DOMAIN={{COOKIE_DOMAIN}}
COOKIE_SECURE={{COOKIE_SECURE}}
COOKIE_SAMESITE={{COOKIE_SAMESITE}}
COOKIE_MAX_AGE={{COOKIE_MAX_AGE}}
COOKIE_MAX_AGE_REMEMBER={{COOKIE_MAX_AGE_REMEMBER}}
COOKIE_NAME={{COOKIE_NAME}}

# Encrypter Configuration
ENCRYPT_KEY={{ENCRYPT_KEY}}

# Internal Configuration
INTERNAL_KEY={{INTERNAL_KEY}}

# Identity Service Configuration
IDENTITY_SERVICE_URL={{IDENTITY_SERVICE_URL}}
IDENTITY_TIMEOUT={{IDENTITY_TIMEOUT}}

# Discord Configuration
DISCORD_WEBHOOK_ID={{DISCORD_WEBHOOK_ID}}
DISCORD_WEBHOOK_TOKEN={{DISCORD_WEBHOOK_TOKEN}}

# LLM Configuration
LLM_PROVIDER={{LLM_PROVIDER}}
LLM_API_KEY={{LLM_API_KEY}}
LLM_MODEL={{LLM_MODEL}}
LLM_TIMEOUT={{LLM_TIMEOUT}}
LLM_MAX_RETRIES={{LLM_MAX_RETRIES}}

# Dry-Run Keyword Sampling Configuration
# Controls how keywords are sampled during dry-run to ensure timeout compliance
# Default values are production-safe (conservative sampling)

# Percentage of keywords to sample (0-100). Default: 10
DRY_RUN_PERCENTAGE=10

# Minimum keywords to ensure representative sample (>= 1). Default: 3
DRY_RUN_MIN_KEYWORDS=3

# Maximum keywords to cap performance. Default: 5
DRY_RUN_MAX_KEYWORDS=5

# Estimated processing time per keyword. Default: 16s
DRY_RUN_KEYWORD_TIME_ESTIMATE=16s

# Sampling strategy: percentage, fixed, or tiered. Default: percentage
DRY_RUN_SAMPLING_STRATEGY=percentage

# Threshold to trigger emergency fallback (reduces to emergency keywords). Default: 70s
DRY_RUN_EMERGENCY_THRESHOLD=70s

# Number of keywords for emergency fallback. Default: 3
DRY_RUN_EMERGENCY_KEYWORDS=3
