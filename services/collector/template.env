# Logger Configuration
LOGGER_LEVEL={{LOGGER_LEVEL}}
LOGGER_MODE={{LOGGER_MODE}}
LOGGER_ENCODING={{LOGGER_ENCODING}}
LOGGER_COLOR_ENABLED={{LOGGER_COLOR_ENABLED}}

# RabbitMQ Configuration
RABBITMQ_URL={{RABBITMQ_URL}}

# Redis Configuration (Standalone mode only)
REDIS_HOST={{REDIS_HOST}}
REDIS_PASSWORD={{REDIS_PASSWORD}}
REDIS_DB={{REDIS_DB}}
REDIS_STATE_DB={{REDIS_STATE_DB}}
REDIS_MIN_IDLE_CONNS={{REDIS_MIN_IDLE_CONNS}}
REDIS_POOL_SIZE={{REDIS_POOL_SIZE}}
REDIS_POOL_TIMEOUT={{REDIS_POOL_TIMEOUT}}

# Project Service Configuration
PROJECT_SERVICE_URL={{PROJECT_SERVICE_URL}}
PROJECT_TIMEOUT={{PROJECT_TIMEOUT}}
PROJECT_INTERNAL_KEY={{PROJECT_INTERNAL_KEY}}
WEBHOOK_RETRY_ATTEMPTS={{WEBHOOK_RETRY_ATTEMPTS}}
WEBHOOK_RETRY_DELAY={{WEBHOOK_RETRY_DELAY}}

# Discord Configuration
DISCORD_REPORT_BUG_ID={{DISCORD_REPORT_BUG_ID}}
DISCORD_REPORT_BUG_TOKEN={{DISCORD_REPORT_BUG_TOKEN}}

# ============================================================================
# CRAWL LIMIT CONFIGURATION
# ============================================================================

# Default limits (used for production crawling)
DEFAULT_LIMIT_PER_KEYWORD=50
DEFAULT_MAX_COMMENTS=100
DEFAULT_MAX_ATTEMPTS=3

# Dry-run limits (for testing/preview)
DRYRUN_LIMIT_PER_KEYWORD=3
DRYRUN_MAX_COMMENTS=5

# Hard limits (safety caps - cannot be exceeded)
MAX_LIMIT_PER_KEYWORD=500
MAX_MAX_COMMENTS=1000

# Feature flags
INCLUDE_COMMENTS=true
DOWNLOAD_MEDIA=false
